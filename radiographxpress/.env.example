# ──────────────────────────────────────────────
#  RadiographXpress — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in production values.
# For Docker: docker-compose reads this file automatically.

# ── Django Core ───────────────────────────────
SECRET_KEY=generate_a_new_secure_random_key_here
DEBUG=False
ALLOWED_HOSTS=your_domain.com,www.your_domain.com,localhost
CSRF_TRUSTED_ORIGINS=https://your_domain.com,https://www.your_domain.com

# ── Database (PostgreSQL) ─────────────────────
# Leave empty to use SQLite for local development
# Docker Compose sets this automatically — no need to change
DATABASE_URL=

# ── Redis (Channel Layer for WebSockets) ──────
# Leave empty to use InMemoryChannelLayer for local development
# Docker Compose sets this automatically — no need to change
REDIS_URL=

# ── PostgreSQL Password (used by docker-compose) ──
POSTGRES_PASSWORD=change_this_to_a_secure_password

# ── Email Configuration (Gmail SMTP) ──────────
# Generate an App Password: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=radiographxpress@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password_here
DEFAULT_FROM_EMAIL=Radiograph Xpress <radiographxpress@gmail.com>

# ── AWS S3 (Media Storage) ────────────────────
USE_S3=True
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# ── Raditech PACS/RIS API ────────────────────
RADITECH_API_URL=https://risapi.grupoptm.com/api
RADITECH_KEY=your_raditech_key
RADITECH_EMAIL=your_raditech_email
RADITECH_PASSWORD=your_raditech_password
RADITECH_ORG_ID=your_org_id
RADITECH_STUDY_SOURCE_ID=your_study_source_id
RADITECH_HOSPITAL_AET=GPTMDEMO
RADITECH_RSP=GPTM
RADITECH_SYNC_INTERVAL=300